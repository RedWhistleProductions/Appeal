Add_Dynamic_Module Graphics Appeal_SDL2_Graphics
Add_Dynamic_Module Breakout Bananas_Breakout
Graphics Debug 0
Breakout Debug 0
Graphics Set_Paths ./Resources
Graphics Add_Window Main "Breakout Smoke Test" 800 520
Graphics Set_FPS 60
Graphics Show Main
Graphics Set_View_Port Main 0 0 800 520
Graphics Set_Ortho Main 0.0 800.0 520.0 0.0 -1.0 1.0
Graphics Load_Font MainFont Tuffy.ttf 24
Breakout Set_Field 800.0 520.0
Breakout Update
Set_Var_Global Paddle_X Breakout.Paddle.X
Set_Var_Global Paddle_Y Breakout.Paddle.Y
Set_Var_Global Paddle_W Breakout.Paddle.W
Set_Var_Global Paddle_H Breakout.Paddle.H
Set_Var_Global Ball_X Breakout.Ball.X
Set_Var_Global Ball_Y Breakout.Ball.Y
Set_Var_Global Ball_Size Breakout.Ball.Size
Graphics Draw_Rect Background 0.0 0.0 800.0 520.0 8 12 18 255
Graphics Draw_Rect Brick_0 44.0 64.0 64.0 22.0 255 107 107 255
Graphics Draw_Rect Brick_1 116.0 64.0 64.0 22.0 255 177 66 255
Graphics Draw_Rect Brick_2 188.0 64.0 64.0 22.0 255 211 105 255
Graphics Draw_Rect Paddle Var Paddle_X Var Paddle_Y Var Paddle_W Var Paddle_H 230 236 245 255
Graphics Draw_Rect Ball Var Ball_X Var Ball_Y Var Ball_Size Var Ball_Size 255 255 255 255
Graphics Draw_Text MainFont "Breakout Smoke" 300.0 16.0
Graphics Render
Graphics Update
Delay 1
Done
